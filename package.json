{
  "name": "qr-data-bridge",
  "private": true,
  "version": "2.0.0-beta",
  "workspaces": [
    "protocol",
    "sender",
    "receiver"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:sender": "npm run dev -w sender",
    "dev:receiver": "npm run dev -w receiver",
    "typecheck": "npm run typecheck --workspaces",
    "size:check": "npm run build --workspaces",
    "build:all": "npm run build -w protocol && npm run build -w sender && npm run build -w receiver",
    "build:pages": "npm run build:all && node scripts/build-pages.mjs"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.9.2",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.5"
  }
}
